    "@react-navigation/native": "^7.0.0",
    "@react-navigation/native-stack": "^7.0.0",
    "backup-folder": "file:./modules/backup-folder",
    "expo": "~54.0.0",
    "expo-asset": "~12.0.0",
    "expo-constants": "~18.0.0",
    "expo-dev-client": "~6.0.21",
    "expo-document-picker": "~14.0.0",
